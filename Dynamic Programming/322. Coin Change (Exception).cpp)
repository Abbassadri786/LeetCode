class Solution {
public:
    int coinChange(vector<int>& coins, int amount) {
        int n = coins.size();
        vector<vector<int>> dp(n+1, vector<int>(amount+1, INT_MAX-1));
        
        //base case
        for(int i=0; i<=n; i++){
            dp[i][0] = 0;
        }
        // Handling 2nd row case
        for(int j=1; j<=amount; j++){
            if(j % coins[0] == 0){
                dp[1][j] = j/coins[0];
            }
        }
        
        // filling up table
        for(int i=2; i<=n; i++){
            for(int j=1; j<=amount; j++){
                if(coins[i-1] <= j){
                                // unbounded knapsack
                    dp[i][j] = min(1 + dp[i][j - coins[i-1]], dp[i-1][j]);
                }
                else{
                    dp[i][j] = dp[i-1][j];
                }
            }
        }
        
        return dp[n][amount] == INT_MAX-1 ? -1 : dp[n][amount];      
    }
};
